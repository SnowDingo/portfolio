---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
---

<Layout title="HOME|SnowDingo">
	<main id="POP">
		<h1><span class="text-gradient">SNOW DINGO</span></h1>
		<h2>Young Game/Web developer</h2>
		<h2 style="margin-top: 10%;">About SNOWDINGO</h2>
		<p>With 8 years of experience working with code, I am a web/game developer who created many projects like book-warden and 3d maze demo.</p>
		<div class="grid">
			<h2>My Project</h2>
			<iframe frameborder="0" src="https://itch.io/embed/1788264?bg_color=1C1D21&amp;fg_color=fefffc&amp;link_color=91C4F2&amp;border_color=fefffc" width="552" height="167"><a href="https://snowdingo.itch.io/book-warden">Book warden by SnowDingo</a></iframe>
			<iframe frameborder="0" src="https://itch.io/embed/2379877?bg_color=1C1D21&amp;fg_color=FEFFFC&amp;link_color=91C4F2&amp;border_color=FEFFFC" width="552" height="167"><a href="https://snowdingo.itch.io/pixel-fishes">PIXEL FISHES by SnowDingo</a></iframe>
		</div>
		<h2 id="Gradient">Contact</h2>
		<p>Email: SnowDingo.tech@gmail.com</p>
		<p>Github: @SnowDingo</p>
		<p>Qiita/Zenn: @FireDingo</p>
	</main>
</Layout>

<script>
	//スクリプト
	function pop(entries){
		if (entries[0].intersectionRatio == 0) {

			return;
		}else{
			pops.classList.add("alpha")
			
	}}
	var Observer = new IntersectionObserver(pop);
	var pops = document.getElementById("POP")
	Observer.observe(pops)
		
</script>
<script>
		//スクリプト
		function gradietn(entries){
		if (entries[0].intersectionRatio == 0) {

			return;
		}else{
			pops.classList.add("gradationanimation")
			
	}}
	var Observer = new IntersectionObserver(gradietn);
	var pops = document.getElementById("Gradient")
	Observer.observe(pops)
</script>

<style>
	@keyframes gradation{
		0%{
			color: #fefffc;
		}
		100%{
			color: #91C4F2;
		}
	}
	.gradationanimation {
		animation: gradation 2s;
		animation-fill-mode: forwards;
	}
	#POP {
		opacity: 0;
	}
	.alpha{
		animation:alpha 1s;
		animation-fill-mode: forwards;
	}
	@keyframes alpha{
		0%{
			opacity: 0;
		}
		100%{
			opacity: 1;
		}
	}
	main {
		margin: auto;
		text-align: center;
		padding: 1rem;
		width: 800px;
		max-width: calc(100% - 2rem);
		color: #fefffc;
		font-size: 20px;
		line-height: 1.6;
	}
	.astro-a {
		position: absolute;
		top: -32px;
		left: 50%;
		transform: translatex(-50%);
		width: 220px;
		height: auto;
		z-index: -1;
	}
	h1 {
		font-size: 4rem;
		font-weight: 700;
		line-height: 1;
		text-align: center;
		margin-bottom: 1em;
	}
	.text-gradient {
		background: -webkit-linear-gradient(#8CA0D7, #91C4F2);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	#アニメーション
	@keyframes bounce {
    0% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
    100% {
      transform: translateY(0);
    }
  }
</style>
